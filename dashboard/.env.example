# NextAuth
AUTH_SECRET=               # Generate with: openssl rand -base64 32
AUTH_URL=https://dashboard.ctslab.net
AUTH_TRUST_HOST=true

# Authentik OIDC
AUTHENTIK_ISSUER=https://auth.ctslab.net/application/o/dashboard/
AUTHENTIK_CLIENT_ID=dashboard-client
AUTHENTIK_CLIENT_SECRET=dashboard-secret-key
AUTHENTIK_JWKS_URI=https://auth.ctslab.net/application/o/p-assistant/jwks/

# Authentik Admin API (for user provisioning during signup)
# Create token: Authentik admin > Directory > Tokens > Create (for akadmin user)
AUTHENTIK_API_TOKEN=
AUTHENTIK_URL=https://auth.ctslab.net

# API
NEXT_PUBLIC_API_URL=https://auth.ctslab.net

# Database (PostgreSQL)
DB_HOST=192.168.1.1
DB_PORT=5434
DB_NAME=ptalk_auth
DB_USER=postgres
DB_PASSWORD=SecurePassword2024

# Email / SMTP (for verification emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@ctslab.net
SMTP_PASS=your-app-password-here
SMTP_FROM=noreply@ctslab.net

# Knowledge Graph (Neo4j edu, read-only)
# Dung port 7688 (edu_neo4j), KHONG phai 7687 (legal_neo4j)
NEO4J_URI=bolt://host.docker.internal:7688
NEO4J_USER=dashboard_ro
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j
KG_CACHE_TTL_MS=60000
